<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>WhiteMetal</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Alumni+Sans:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Main CSS -->
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/login-register.css">

</head>
<body>
  <div class="bg-gradient-layer"></div>

  {{#if isAuthPage}}
    {{> navbar-auth}}
  {{else if isDashboard}}
    {{> navbar-dashboard}}
  {{else}}
    {{> navbar}}
  {{/if}}
  

  {{{body}}}
  

  <div class="toast-container position-fixed bottom-0 start-50 translate-middle-x p-3">

  <div id="cartToast" class="toast align-items-center text-bg-danger border-0" role="alert">

    <div class="d-flex">

      <div class="toast-body" id="toastMessage">
        Message
      </div>

      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>

    </div>

  </div>

</div>


  <!-- JS -->
  <script src="/js/cart.js"></script>
  <script src="/js/productPricing.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  
</body>
</html>