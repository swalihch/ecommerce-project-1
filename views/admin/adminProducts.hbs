<div class="admin-container">

  <div
    class="admin-header d-flex justify-content-between align-items-center flex-wrap gap-3"
  >

    <h2 class="mb-0">Product Management</h2>

    <form action="/admin/products" method="GET" class="d-flex gap-2">
      <input
        type="text"
        name="search"
        value="{{search}}"
        class="form-control"
        placeholder="Search products..."
      />
      <button type="submit" class="btn btn-primary">
        Search
      </button>
      <a href="/admin/products" class="btn btn-danger">
        Clear
      </a>
    </form>

    <a href="/admin/products/add" class="btn btn-success">
      + Add Product
    </a>

  </div>

  <div class="stats">
    <div>Total Products: {{totalProducts}}</div>
    <div>Total Orders: 0</div>
    <div>Revenue: ₹0</div>
  </div>

  <div class="table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Product</th>
          <th>Price</th>
          <th>Category</th>
          <th>Stock</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        {{#each products}}
          <tr>
            <td>
              <img src="{{this.image}}" width="50" />
            </td>
            <td>{{this.name}}</td>
            <td>₹{{this.price}}</td>
            <td>{{this.category}}</td>
            <td>{{this.stock}}</td>

            <td class="actions">
              <a href="/admin/products/edit/{{this._id}}" class="edit-btn">
                Edit
              </a>

              <form
                action="/admin/products/delete/{{this._id}}"
                method="POST"
                onsubmit="return confirm('Are you sure?')"
              >
                <button type="submit" class="delete-btn">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<div class="d-flex justify-content-center mt-4 w-100">

  <!-- PREV -->
  {{#if (gt @root.currentPage 1)}}
    <a
      href="/admin/products?search={{@root.search}}&page={{subtract
        @root.currentPage
        1
      }}"
      class="btn btn-outline-secondary mx-1"
    >
      Prev
    </a>
  {{/if}}

  <!-- PAGE NUMBERS -->
  {{#each (range 1 @root.totalPages)}}
    <a
      href="/admin/products?search={{@root.search}}&page={{this}}"
      class="btn
        {{ifEquals @root.currentPage this 'btn-primary' 'btn-outline-primary'}}
        mx-1"
    >
      {{this}}
    </a>
  {{/each}}

  <!-- NEXT -->
  {{#if (lt @root.currentPage @root.totalPages)}}
    <a
      href="/admin/products?search={{@root.search}}&page={{add
        @root.currentPage
        1
      }}"
      class="btn btn-outline-secondary mx-1"
    >
      Next
    </a>
  {{/if}}

</div>