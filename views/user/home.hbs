<main>
  <div class="container mb-4">

    <div class="d-flex gap-2">

      <a href="/" class="btn btn-outline-dark">All</a>

      <a href="/?category=Door" class="btn btn-outline-primary">
        Door
      </a>

      <a href="/?category=Sheet" class="btn btn-outline-primary">
        Sheet
      </a>

      <a href="/?category=Accessory" class="btn btn-outline-primary">
        Accessory
      </a>

    </div>

  </div>

  <div class="container mt-4">

    <form action="/" method="GET" class="d-flex mb-4">

      <input
        type="text"
        name="search"
        value="{{search}}"
        class="form-control me-2"
        placeholder="Search products..."
      />

      <button class="btn btn-primary">
        Search
      </button>

    </form>

  </div>

  <section class="products">
    <div class="container">
      <div class="row g-4">
        <!-- first card -->

        {{#each products}}
          <div class="col-lg-3 col-md-6">

            <div
              class="card product-card h-100 shadow-sm"
              data-price="{{price}}"
              data-discount="{{discount}}"
            >

              <div class="position-relative">

                <span class="badge discount-badge"></span>

                <a href="/product/{{_id}}">
                  <img
                    class="card-img-top product-img"
                    src="{{image}}"
                    alt="{{name}}"
                  />
                </a>

              </div>

              <div class="card-body d-flex flex-column">

                <a
                  href="/product/{{_id}}"
                  class="text-decoration-none text-dark"
                >
                  <h6 class="card-title product-title">
                    {{name}}
                  </h6>
                </a>

                <p class="saveText text-success small"></p>

                <p class="card-text fw-bold text-danger mb-2">

                  <span
                    class="originalPrice text-muted text-decoration-line-through"
                  ></span>
                  <span class="finalPrice ms-2"></span>

                </p>

                <!-- Add to cart -->

                <form
                  action="/add-to-cart/{{_id}}"
                  method="POST"
                  class="mt-auto d-flex gap-2"
                >

                  <input
                    type="hidden"
                    name="redirect"
                    value="{{@root.currentUrl}}"
                  />

                  <input
                    type="number"
                    name="quantity"
                    min="1"
                    value="1"
                    class="form-control form-control-sm w-25"
                  />

                  <button
                    type="button"
                    class="btn btn-danger btn-sm flex-grow-1 add-to-cart-btn"
                    data-id="{{_id}}"
                  >
                    Add to Cart
                  </button>

                </form>

              </div>

            </div>

          </div>
        {{/each}}
      </div>

    </div>
  </section>

</main>



