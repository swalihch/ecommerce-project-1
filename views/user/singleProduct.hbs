<div class="container mt-5">

  <a href="/" class="btn btn-outline-secondary mb-4">
    ← Back to Products
  </a>

  <div class="row align-items-center">

    <!-- Product Image -->
    <div class="col-md-5 text-center position-relative">

      {{#if singleProduct.discount}}
        <span class="badge bg-danger position-absolute top-0 start-0 m-2">
          {{singleProduct.discount}}% OFF
        </span>
      {{/if}}

      <img
        src="{{singleProduct.image}}"
        class="img-fluid rounded shadow"
        style="max-height:400px; object-fit:contain;"
      />

    </div>

    <!-- Product Details -->
    <div class="col-md-7">

      <h2 class="mb-3">{{singleProduct.name}}</h2>

      <p class="text-muted">
        Category:
        {{singleProduct.category}}
      </p>

      {{#if error}}
        <div class="alert alert-danger">
          Not enough stock available
        </div>
      {{/if}}

      <!-- Price Section -->

      {{#if singleProduct.discount}}

        <p class="mb-2">

          <span class="text-muted text-decoration-line-through fs-5">
            ₹{{singleProduct.price}}
          </span>

          <span class="text-danger fs-3 ms-2">
            ₹{{finalPrice}}
          </span>

        </p>

        <p class="text-success">
          You save ₹{{savedAmount}}
          ({{singleProduct.discount}}% OFF)
        </p>

      {{else}}

        <h3 class="text-danger">
          ₹{{singleProduct.price}}
        </h3>

      {{/if}}

      <!-- Stock indicator -->

      {{#if singleProduct.stock}}
        <p class="text-success">
          ✔ In Stock
        </p>
      {{else}}
        <p class="text-danger">
          Out of Stock
        </p>
      {{/if}}

      <!-- Description -->

      <p class="mt-3 mb-4">
        {{singleProduct.description}}
      </p>

      <!-- Add to cart -->

      <form class="d-flex gap-2">

        <input
          type="number"
          name="quantity"
          min="1"
          value="1"
          class="form-control w-25"
        />

        {{#if singleProduct.stock}}

          <button
            class="btn btn-danger px-4 add-to-cart-btn"
            data-id="{{singleProduct._id}}"
          >
            Add to Cart
          </button>

        {{else}}

          <button class="btn btn-secondary px-4" disabled>
            Out of Stock
          </button>

        {{/if}}

      </form>

    </div>

  </div>

</div>